ehthumbs.db

# Linux
*~
.nfs*

# 打包 / 导出文件
*.apk
*.aab
*.xcodeproj/
*.xcworkspace/
*.xcuserstate
*.ipa
*.unitypackage

# Unity 崩溃转储 / 性能分析等
sysinfo.txt
crashlytics-build.properties

# 日志与其他临时文件
*.log
*.stacktrace
*.playback
*.pid

# 本地用户设置
UserSettings/
*.local

