.vs/
.idea/
*.unityproj

# VS Code
.vscode/*
!.vscode/settings.json
!.vscode/tasks.json
!.vscode/launch.json
!.vscode/extensions.json

# Rider 插件缓存
*.csproj.DotSettings

# 操作系统级忽略
# Windows
[Tt]humbs.db
[Dd]esktop.ini
$RECYCLE.BIN/

